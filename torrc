# Nightshade Tor configuration
# Ports chosen to avoid conflict with Tor Browser (9050/9051)

# Bind both ports explicitly to localhost — not accessible from the network
SOCKSPort 127.0.0.1:9055
ControlPort 127.0.0.1:9056

# Cookie auth: tor writes a random secret to tor-data/control_auth_cookie.
# tor-daemon.mjs reads it before sending NEWNYM, so no unauthenticated access.
CookieAuthentication 1

# Store data next to this config so the daemon is fully self-contained
DataDirectory ./tor-data

# Log bootstrap progress to stdout — daemon watches for "Bootstrapped 100%"
Log notice stdout

# Discard old logs on startup
TruncateLogFile 1

# Don't act as a relay
SocksPolicy accept 127.0.0.1
SocksPolicy reject *

# Reasonable circuit settings (hidden services often need longer first connect)
NewCircuitPeriod 30
MaxCircuitDirtiness 600
CircuitBuildTimeout 60
LearnCircuitBuildTimeout 1
PathsNeededToBuildCircuits 0.25

# Exit nodes: no exit to protect other users; we are a client only
ExitPolicy reject *:*
